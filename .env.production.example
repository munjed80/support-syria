# ─── Production Environment Variables ────────────────────────────────────────
# Copy to .env and fill in real values before deploying.

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=municipal_requests
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── FastAPI / Backend ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_RANDOM_HEX_64

# CORS – comma-separated origins (your public domain)
CORS_ORIGINS=https://yourdomain.com

# Rate limit for public request submission (per IP per hour)
RATE_LIMIT_PER_HOUR=10

# Uvicorn workers (2× CPU cores is a good starting point)
UVICORN_WORKERS=2

# ─── Nginx ───────────────────────────────────────────────────────────────────
# Host port that Nginx listens on (use 80 or put behind a reverse proxy)
HTTP_PORT=80
